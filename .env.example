# ================================================================
# CRM Praxis — Variáveis de Ambiente
# Copie para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais.
# ================================================================

# ── Supabase (frontend) ────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<seu-anon-key>

# ── n8n (frontend — ações financeiras) ────────────────────────
# URL base do seu n8n (sem barra final). Usado para chamar os
# webhooks de ações financeiras: /webhook/finance/{action}
VITE_N8N_WEBHOOK_URL=https://seu-n8n.com

# ── Supabase Edge Functions Secrets ───────────────────────────
# Configurar no Supabase Dashboard → Edge Functions → Secrets
# (NÃO vão para o .env local — ficam no servidor)
#
# ASAAS_API_KEY             = $aact_xxxxxxxxxxxx
# ASAAS_ENV                 = sandbox | production
# ASAAS_WEBHOOK_SECRET      = <token gerado no painel Asaas>
#                             Asaas → Configurações → Notificações → Token

# ── n8n — Variáveis de Ambiente do Workflow ───────────────────
# Configurar em n8n → Settings → Variables
#
# SUPABASE_URL              = https://<project-ref>.supabase.co
# SUPABASE_EDGE_URL         = https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY         = <seu-anon-key>
# SUPABASE_SERVICE_ROLE_KEY = <service-role-key>  ← nunca expor no frontend!
#
# N8N_WEBHOOK_URL           = https://seu-n8n.com/webhook/asaas-webhook
#   ↑ URL que deve ser configurada no painel Asaas:
#   Asaas → Configurações → Notificações → URL do Webhook

# ── WhatsApp (Z-API ou equivalente) ───────────────────────────
# Configurar em n8n → Settings → Variables
#
# ZAPI_INSTANCE             = <id-da-instancia>
# ZAPI_TOKEN                = <token-da-instancia>
# ZAPI_CLIENT_TOKEN         = <client-token-zapi>
# AGENCY_DEFAULT_PHONE      = 5511999999999   (DDI+DDD+número, sem espaços)
